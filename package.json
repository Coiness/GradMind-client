    "test": "vitest --run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "@reduxjs/toolkit": "^2.10.1",
    "@types/mathjs": "^9.4.1",
    "antd": "^5.28.1",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "mathjs": "^15.1.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.9.5",
    "reactflow": "^11.11.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/ui": "^4.0.18",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
